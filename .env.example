# BG D-Pilot Configuration
# Copy to .env and fill in values

# Server
PORT=3101
NODE_ENV=development

# JWT Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=24h

# Database Connections (JSON array)
# Each connection: { id, name, env, type, host, port, database, username, password, schema? }
# Types: postgres, mssql, mongodb, elasticsearch
# Envs: DEV, QA, STG, PROD
DBFORGE_CONNECTIONS='[
  {
    "id": "dev-pg",
    "name": "Dev PostgreSQL",
    "env": "DEV",
    "type": "postgres",
    "host": "localhost",
    "port": 5432,
    "database": "mydb",
    "username": "",
    "password": "",
    "schema": "public"
  },
  {
    "id": "dev-mssql",
    "name": "Dev SQL Server",
    "env": "DEV",
    "type": "mssql",
    "host": "localhost",
    "port": 1433,
    "database": "mydb",
    "username": "",
    "password": ""
  },
  {
    "id": "dev-mongo",
    "name": "Dev MongoDB",
    "env": "DEV",
    "type": "mongodb",
    "uri": "mongodb://localhost:27017/mydb"
  }
]'

# PHI Masking
PHI_ALWAYS_MASKED=true
PHI_ADMIN_CAN_UNMASK=true

# Branding
APP_NAME=D-Pilot
# Logo URL — local path (place file in public/) or external URL. Leave empty for text-only header.
LOGO_URL=

# Email Domain (used for default admin seed and user creation validation)
EMAIL_DOMAIN=example.com

# Default admin password (used only when seeding the first admin user)
DEFAULT_ADMIN_PASSWORD=changeme123

# Query Safety
MAX_ROWS=10000
QUERY_TIMEOUT_MS=30000
